# ── Database ────────────────────────────────────────────────────────────────
# Neon pooled URL (runtime)
DATABASE_URL=postgresql://...?sslmode=require&pgbouncer=true&connection_limit=1
# Neon direct URL (Prisma migrations only)
DIRECT_URL=postgresql://...?sslmode=require

# ── Seed ─────────────────────────────────────────────────────────────────────
# Password for the seeded admin user (info@lhccapital.org). Set before running prisma db seed.
SEED_PASSWORD=change-me-before-seeding

# ── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key for SocialAccount.accessToken at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Local: http://localhost:3004  |  Production: https://studio.lhccapital.org
NEXTAUTH_URL=https://studio.lhccapital.org

# ── AI APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FAL_KEY=

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=capital-studio
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Social OAuth ─────────────────────────────────────────────────────────────
# Facebook / Instagram (Meta)
META_APP_ID=
META_APP_SECRET=

# X (Twitter) — OAuth 1.0a (used for posting)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
# OAuth 2.0 (Phase 2 — future connect flow)
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google (YouTube)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# HeyGen (Likeness Video)
HEYGEN_API_KEY=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Defaults: analytics/music/scheduler/facebook/instagram/threads/linkedin/x = ON
# Phase 2 modules default OFF — set to 'true' to enable
# FLAG_VIDEO_GENERATION=true
# FLAG_VOICEOVER=true
# FLAG_MOTION_VIDEO=true
# FLAG_LIKENESS_VIDEO=true
# FLAG_SOCIAL_YOUTUBE=true
# FLAG_SOCIAL_TIKTOK=true

# ElevenLabs (VoiceOver)
ELEVENLABS_API_KEY=
