# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...

# ── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3004

# ── AI APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FAL_KEY=

# ── Storage ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ── Social OAuth ─────────────────────────────────────────────────────────────
# Facebook / Instagram (Meta)
META_APP_ID=
META_APP_SECRET=

# X (Twitter)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google (YouTube)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# HeyGen (Likeness Video)
HEYGEN_API_KEY=

# ElevenLabs (VoiceOver)
ELEVENLABS_API_KEY=
